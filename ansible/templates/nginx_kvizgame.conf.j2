# KvizGame — nginx snippets for the zelgray.work server block.
# Add both location blocks to the existing server { } in the infra repo.
#
# Discord Activity Developer Portal settings:
#   Root URL  : https://zelgray.work/kvizgame/
#   URL Mapping — Prefix: /api  Target: zelgray.work
#     (Discord strips the /api prefix and routes to zelgray.work/<rest>)

# Frontend static files: served by aiohttp from the built dist volume.
# Discord routes all Activity requests not matched by /api here.
location /kvizgame/ {
    proxy_pass         http://127.0.0.1:{{ kvizgame_port }}/;
    proxy_http_version 1.1;
    proxy_set_header   Host       $host;
    proxy_set_header   X-Real-IP  $remote_addr;
}

# KvizGame API: reached after Discord strips the /api prefix.
# Covers: POST /token, /sessions, DELETE /sessions/*, GET /media/*, WS /ws/*
location ~ ^/(token|sessions|media|ws)(/|$) {
    proxy_pass         http://127.0.0.1:{{ kvizgame_port }};
    proxy_http_version 1.1;
    proxy_set_header   Upgrade    $http_upgrade;
    proxy_set_header   Connection "upgrade";
    proxy_set_header   Host       $host;
    proxy_set_header   X-Real-IP  $remote_addr;
    proxy_read_timeout 3600;
}
