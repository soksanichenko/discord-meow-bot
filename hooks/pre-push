#!/usr/bin/env bash
# Squash all unpushed commits into one before pushing.
# Uses the most recent commit message as the squashed message.
# Skip with: git push --no-verify
set -eo pipefail

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    # Branch deletion — nothing to squash.
    [[ "$local_sha" == "0000000000000000000000000000000000000000" ]] && continue
    # New remote branch — nothing to squash against.
    [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]] && continue

    count=$(git rev-list --count "$remote_sha..$local_sha")
    [[ "$count" -le 1 ]] && continue

    msg=$(git log -1 --format="%B" "$local_sha")
    echo "pre-push: squashing $count commits into one..."
    git reset --soft "$remote_sha"
    git commit --no-verify -m "$msg"
done
